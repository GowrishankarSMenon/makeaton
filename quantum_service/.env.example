# IBM Quantum Configuration
# Get your token from https://quantum.ibm.com
IBM_QUANTUM_TOKEN=your_api_token_here
IBM_QUANTUM_INSTANCE=ibm-q/open/main

# Execution preferences
# local   = always use local simulator (no IBM account needed)
# ibm     = prefer IBM Quantum, fallback to local on failure
# ibm_sim = use IBM cloud simulator only (no real hardware)
QUANTUM_MODE=local

# Max retries for IBM Quantum jobs before falling back to local
IBM_MAX_RETRIES=3

# Timeout for IBM Quantum jobs in seconds (real hardware can queue)
IBM_JOB_TIMEOUT=300
